{
  "name": "library-system-e2e-testing",
  "version": "1.0.0",
  "description": "End-to-End and UI Testing for Library Management System v2 using Playwright",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {},
  "keywords": [
    "playwright",
    "e2e-testing",
    "library-system",
    "jest",
    "unit-tests"
  ],
  "author": "",
  "license": "MIT"
}
